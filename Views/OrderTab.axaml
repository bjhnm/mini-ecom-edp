<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.OrderTab"             x:DataType="vm:OrderTabViewModel">    <Design.DataContext>        <vm:OrderTabViewModel/>    </Design.DataContext>    <Grid Margin="12,0,12,0">        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />            <RowDefinition Height="Auto" />        </Grid.RowDefinitions>        <!-- Header with title, search, and record count -->        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">                    <TextBlock Text="Sales Orders" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center" />                    <Border Background="#F0EEFF" CornerRadius="12" Padding="8,2,8,2" VerticalAlignment="Center">                        <TextBlock Text="{Binding FilteredItems.Count}" FontSize="13" FontWeight="SemiBold" Foreground="#5748FA" />                    </Border>                </StackPanel>                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                         PlaceholderText="Search orders, customers, payments..."                         Classes="search"                         HorizontalAlignment="Stretch"                         VerticalAlignment="Center"                         Margin="24,0,0,0" />            </Grid>        </Border>        <!-- DataGrid -->        <Border Grid.Row="1" Classes="card" Padding="0" Margin="0,0,0,8">            <DataGrid ItemsSource="{Binding FilteredItems}"                      VerticalAlignment="Stretch"                      HorizontalAlignment="Stretch"                      GridLinesVisibility="Horizontal"                      BorderThickness="0"                      Grid.Row="1"                      AutoGenerateColumns="False"                      RowHeight="44" CanUserResizeColumns="True">                <DataGrid.Columns>                    <DataGridTextColumn Header="Order ID" IsReadOnly="True" Binding="{Binding Order.OrderId}" />                    <DataGridTextColumn Header="Customer" IsReadOnly="True" Binding="{Binding CustomerName}" Width="150" />                    <DataGridTextColumn Header="Date" IsReadOnly="True" Binding="{Binding Order.OrderDate}" Width="120" />                    <DataGridTextColumn Header="Total" IsReadOnly="True" Binding="{Binding Payment.Amount}" Width="100" />                    <DataGridTextColumn Header="Method" Binding="{Binding Payment.PaymentMethod}" Width="110" />                    <DataGridTextColumn Header="Status" Binding="{Binding Payment.PaymentStatus}" Width="110" />                    <DataGridTemplateColumn Header="" Width="100">                        <DataGridTemplateColumn.CellTemplate>                            <DataTemplate>                                <Button Content="View" Classes="secondary" Padding="12,4" FontSize="12"                                        Command="{Binding DataContext.OpenOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"                                        CommandParameter="{Binding}" />                            </DataTemplate>                        </DataGridTemplateColumn.CellTemplate>                    </DataGridTemplateColumn>                </DataGrid.Columns>            </DataGrid>        </Border>        <!-- Bottom toolbar -->        <Border Grid.Row="2" Background="White" Padding="0,8,0,0" Margin="0,0,0,8">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">                    <Button Command="{Binding CreateNewOrderCommand}" Classes="primary">                        <StackPanel Orientation="Horizontal" Spacing="6">                            <TextBlock VerticalAlignment="Center" Text="+" FontSize="16" FontWeight="Bold" />                            <TextBlock VerticalAlignment="Center" Text="New Order" />                        </StackPanel>                    </Button>                </StackPanel>                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding OrderCancelChangesCommand}" Classes="danger">                        Cancel Changes                    </Button>                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding OrderSaveChangesCommand}" Classes="primary">                        Save Changes                    </Button>                </StackPanel>            </Grid>        </Border>    </Grid></UserControl>