<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
    d:DesignWidth="380" d:DesignHeight="420" Width="380" Height="420"
    WindowStartupLocation="CenterOwner" CanResize="False" CanMaximize="False"
    x:Class="mvvm_edp.Views.ProfileDialog" Icon="/Assets/app.ico" Title="Profile">
    <StackPanel Spacing="28" Margin="36">
        <StackPanel HorizontalAlignment="Center" Spacing="12">
            <Border Width="72" Height="72" CornerRadius="36" Background="#F0EEFF"
                HorizontalAlignment="Center">
                <TextBlock Text="A" FontSize="32" FontWeight="Bold" Foreground="#5748FA"
                    HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Jhan" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"
                HorizontalAlignment="Center" />
            <Border Background="#F0EEFF" CornerRadius="4" Padding="12,4"
                HorizontalAlignment="Center">
                <TextBlock Text="Administrator" FontSize="12" FontWeight="SemiBold"
                    Foreground="#5748FA" />
            </Border>
        </StackPanel>
        <Border Height="1" Background="#E8E8E8" Margin="0" />
        <StackPanel Spacing="18">
            <Grid ColumnDefinitions="124, *">
                <TextBlock Text="Email:" FontSize="14" Foreground="#888" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="jhan@edp.com" FontSize="14" Foreground="#333"
                    VerticalAlignment="Center" />
            </Grid>
            <Grid ColumnDefinitions="125, *">
                <TextBlock Text="Member Since:" FontSize="14" Foreground="#888"
                    VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="January 2024" FontSize="14" Foreground="#333"
                    VerticalAlignment="Center" />
            </Grid>
            <Grid ColumnDefinitions="125, *">
                <TextBlock Text="Last Login:" FontSize="14" Foreground="#888"
                    VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Today" FontSize="14" Foreground="#333"
                    VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </StackPanel>
</Window>