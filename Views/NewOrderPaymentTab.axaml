<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.NewOrderPaymentTab"             x:DataType="vm:NewOrderPaymentTabViewModel">    <Design.DataContext>        <!-- This only sets the DataContext for the previewer in an IDE,        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->        <vm:NewOrderPaymentTabViewModel/>    </Design.DataContext>    <!--    <Window.Styles>    <Style Selector="DataValidationErrors">    <Setter Property="BorderBrush" Value="Red"/>    <Setter Property="BorderThickness" Value="2"/>    </Style>    </Window.Styles>    -->    <Grid RowDefinitions="Auto, *, Auto" Margin="0, 0, 0, 0">        <!-- <Grid Grid.Row="0">            <Label Margin="0, 10, 0, 10" HorizontalAlignment="Center" FontWeight="Bold">Payment</Label>        </Grid>        -->        <Grid  Grid.Row="1" RowDefinitions="Auto, *, Auto, Auto">            <!-- Customer Information -->            <Border Grid.Row="0" Margin="0, 8, 0, 8" BorderBrush="#E8E8E8"                    BorderThickness="1"                    Padding="10"                    CornerRadius="8">                <StackPanel >                    <Grid ColumnDefinitions="*, *, *">                        <Grid Grid.Column="0" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">Customer ID: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Buyer.CustomerId}"/>                        </Grid>                        <Grid Grid.Column="1" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">First Name: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Buyer.FirstName}"/>                        </Grid>                        <Grid Grid.Column="2" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">Last Name: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Buyer.LastName}"/>                        </Grid>                    </Grid>                    <Grid ColumnDefinitions="Auto, *">                        <Label Grid.Column="0" VerticalAlignment="Center">Phone: </Label>                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Buyer.Phone}"/>                    </Grid>                    <Grid ColumnDefinitions="Auto, *">                        <Label Grid.Column="0" VerticalAlignment="Center">Address: </Label>                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Buyer.Address}"/>                    </Grid>                </StackPanel>            </Border>            <!-- Cart -->            <DataGrid Grid.Row="1" ItemsSource="{Binding Cart}" VerticalAlignment="Stretch" GridLinesVisibility="All" AutoGenerateColumns="False" CanUserResizeColumns="True">                <DataGrid.Columns>                    <DataGridTextColumn Header="Product ID" IsReadOnly="True" Binding="{Binding Item.ProductId}" />                    <DataGridTextColumn Header="Name" IsReadOnly="True"  Binding="{Binding Product.Name, Mode=TwoWay}" />                    <DataGridTextColumn Header="Description" IsReadOnly="True"  Binding="{Binding Product.Description, Mode=TwoWay}" />                    <DataGridTextColumn Header="Price" IsReadOnly="True"  Binding="{Binding Product.Price, Mode=TwoWay}" />                    <DataGridTextColumn Header="Quantity"  Binding="{Binding Item.Quantity, Mode=TwoWay}" />                </DataGrid.Columns>            </DataGrid>            <!-- Payment -->            <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0, 8, 0, 0">                <Grid Grid.Column="0" Margin="0, 0, 0, 10" ColumnDefinitions="Auto, *">                    <Label VerticalAlignment="Center" Grid.Column="0">                        Payment Method:                    </Label>                    <ComboBox Grid.Column="1" ItemsSource="{Binding PaymentMethods}" SelectedValue="{Binding Paymentmethod, Mode=TwoWay}" />                </Grid>                <Grid Grid.Column="1" Margin="0, 0, 0, 10" ColumnDefinitions="Auto, *">                    <Label VerticalAlignment="Center" Grid.Column="0">                        Payment Status:                    </Label>                    <ComboBox Grid.Column="1" ItemsSource="{Binding PaymentStates}" SelectedValue="{Binding Paymentstatus, Mode=TwoWay}" />                </Grid>            </Grid>            <!-- Total-->            <Grid Grid.Row="3" Margin="0, 0, 0, 0" RowDefinitions="Auto, *">                <Border Grid.Row="4" Margin="0, 0, 0, 0" BorderBrush="#E8E8E8"                        BorderThickness="1"                        Padding="10"                        CornerRadius="8">                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">                        <Label VerticalAlignment="Center" FontSize="20">Total:</Label><TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Black" Text="{Binding Amount, StringFormat='{}{0:C}'}"></TextBlock>                    </StackPanel>                </Border>            </Grid>        </Grid>        <Grid Margin="0, 10, 0, 0" Grid.Row="2" ColumnDefinitions="*, Auto, Auto">            <Button Margin="0, 0, 8, 0" Grid.Column="1"                    Command="{Binding PreviousCommand}"                    Classes="secondary">Previous</Button>            <Button Grid.Column="2"                    Command="{Binding SaveOrderCommand}"                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}"                    Classes="primary">Save</Button>        </Grid>    </Grid></UserControl>