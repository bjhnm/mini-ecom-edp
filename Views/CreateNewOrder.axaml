<Window xmlns="https://github.com/avaloniaui"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        xmlns:vm="using:mvvm_edp.ViewModels"        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        xmlns:models="using:mvvm_edp.Models"        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"        Width="900" Height="550"        CanResize="False"        CanMaximize="False"        x:Class="mvvm_edp.Views.CreateNewOrder"        x:DataType="vm:CreateNewOrderViewModel"        Icon="/Assets/app.ico"        Title="Create New Order">    <Design.DataContext>        <!-- This only sets the DataContext for the previewer in an IDE,        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->        <vm:CreateNewOrderViewModel/>    </Design.DataContext>    <Grid RowDefinitions="*">        <TabControl x:Name="Tabs" Margin="8" TabStripPlacement="Left"                    ItemsSource="{Binding Tabs}"                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"                    SelectionChanged="OnTabChanged">            <TabControl.ItemTemplate>                <DataTemplate>                    <TextBlock FontSize="13" Text="{Binding Title}" />                </DataTemplate>            </TabControl.ItemTemplate>        </TabControl>    </Grid>    <!--    <Window.Styles>    <Style Selector="DataValidationErrors">    <Setter Property="BorderBrush" Value="Red"/>    <Setter Property="BorderThickness" Value="2"/>    </Style>    </Window.Styles>    --></Window>