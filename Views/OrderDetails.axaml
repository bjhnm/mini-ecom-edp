<Window xmlns="https://github.com/avaloniaui"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        xmlns:vm="using:mvvm_edp.ViewModels"        x:Class="mvvm_edp.Views.OrderDetails"        x:DataType="vm:OrderDetailsViewModel"        Title="Order Details"        Width="550" Height="400"        CanResize="True"        WindowStartupLocation="CenterOwner">    <Grid Margin="16" RowDefinitions="Auto, Auto, *, Auto">        <Label Grid.Row="0" Margin="0, 0, 0, 4"               HorizontalAlignment="Center"               FontWeight="Bold" FontSize="16"               Foreground="#333">Order Details</Label>        <Border Grid.Row="1" Margin="0, 0, 0, 12"                Padding="10" CornerRadius="8"                BorderBrush="#E8E8E8" BorderThickness="1"                Background="#F9F9F9">            <TextBlock Text="{Binding OrderSummary}"                       FontSize="13" Foreground="#555" />        </Border>        <DataGrid Grid.Row="2"                  ItemsSource="{Binding Items}"                  GridLinesVisibility="All"                  AutoGenerateColumns="False"                  IsReadOnly="True"                  CanUserResizeColumns="True"                  RowHeight="36">            <DataGrid.Columns>                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />                <DataGridTextColumn Header="Price" Binding="{Binding ProductPrice, StringFormat=C}" Width="100" />                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80" />                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="100" />            </DataGrid.Columns>        </DataGrid>        <Button Grid.Row="3" Margin="0, 12, 0, 0"                HorizontalAlignment="Right"                Classes="secondary"                Click="OnCloseClick">Close</Button>    </Grid></Window>