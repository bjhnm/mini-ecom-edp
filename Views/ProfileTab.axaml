<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             x:Class="mvvm_edp.Views.ProfileTab"             x:DataType="vm:ProfileTabViewModel">    <Grid>        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />        </Grid.RowDefinitions>        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">                <TextBlock Text="Profile" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center" />            </StackPanel>        </Border>        <Border Grid.Row="1" Classes="card" Padding="0" Margin="0,0,0,8">            <Grid Margin="32" ColumnDefinitions="Auto, *">                <Border Grid.Column="0" Width="120" Height="120" CornerRadius="60" Background="#F0EEFF"                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,32,0">                    <TextBlock Text="A" FontSize="48" FontWeight="Bold"                               Foreground="#5748FA" HorizontalAlignment="Center" VerticalAlignment="Center" />                </Border>                <StackPanel Grid.Column="1" Spacing="16">                    <StackPanel Spacing="4">                        <TextBlock Text="Username" FontSize="12" Foreground="#888" />                        <TextBlock Text="{Binding Username}" FontSize="18" FontWeight="Bold" Foreground="#1A1A2E" />                    </StackPanel>                    <StackPanel Spacing="4">                        <TextBlock Text="Role" FontSize="12" Foreground="#888" />                        <Border Background="#F0EEFF" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">                            <TextBlock Text="{Binding Role}" FontSize="13" FontWeight="SemiBold" Foreground="#5748FA" />                        </Border>                    </StackPanel>                    <StackPanel Spacing="4">                        <TextBlock Text="Email" FontSize="12" Foreground="#888" />                        <TextBlock Text="{Binding Email}" FontSize="15" Foreground="#333" />                    </StackPanel>                    <StackPanel Spacing="4">                        <TextBlock Text="Member Since" FontSize="12" Foreground="#888" />                        <TextBlock Text="{Binding MemberSince}" FontSize="15" Foreground="#333" />                    </StackPanel>                    <StackPanel Spacing="4">                        <TextBlock Text="Last Login" FontSize="12" Foreground="#888" />                        <TextBlock Text="{Binding LastLogin}" FontSize="15" Foreground="#333" />                    </StackPanel>                </StackPanel>            </Grid>        </Border>    </Grid></UserControl>