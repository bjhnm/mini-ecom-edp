<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
    xmlns:vm="using:mvvm_edp.ViewModels" x:Class="mvvm_edp.Views.ReportTab"
    x:DataType="vm:ReportTabViewModel">
    <Grid Margin="24,24,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">
            <Grid ColumnDefinitions="Auto, *, Auto" >
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Reports" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"
                        VerticalAlignment="Center" />
                    <ComboBox Width="200" SelectedIndex="{Binding SelectedReportIndex, Mode=TwoWay}"
                        VerticalAlignment="Center">
                        <ComboBoxItem>Sales</ComboBoxItem>
                        <ComboBoxItem>Inventory</ComboBoxItem>
                        <ComboBoxItem>Customers</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Classes="secondary" />
                    <Button Content="Export to Excel" Command="{Binding ExportCommand}"
                        Classes="primary" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Classes="card" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="True"
                GridLinesVisibility="Horizontal" BorderThickness="0" CanUserResizeColumns="True"
                RowHeight="36" IsReadOnly="True" />
        </Border>
    </Grid>
</UserControl>