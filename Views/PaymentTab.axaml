<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.PaymentTab"             x:DataType="vm:PaymentTabViewModel">    <Design.DataContext>        <vm:PaymentTabViewModel/>    </Design.DataContext>    <Grid Margin="12,0,12,0">        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />            <RowDefinition Height="Auto" />        </Grid.RowDefinitions>        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">                    <TextBlock Text="Payments" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center" />                    <Border Classes="badge" VerticalAlignment="Center">                        <TextBlock Text="{Binding FilteredItems.Count}" Classes="badge" />                    </Border>                </StackPanel>                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                         PlaceholderText="Search payments..." Classes="search"                         HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24,0,0,0" />            </Grid>        </Border>        <Border Grid.Row="1" Classes="card" Padding="0" Margin="0,0,0,8">            <DataGrid ItemsSource="{Binding FilteredItems}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"                      GridLinesVisibility="Horizontal" BorderThickness="0" AutoGenerateColumns="False" RowHeight="44" CanUserResizeColumns="True">                <DataGrid.Columns>                    <DataGridTextColumn Header="Payment ID" IsReadOnly="True" Binding="{Binding PaymentId}" Width="100" />                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId, Mode=TwoWay}" Width="100" />                    <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, Mode=TwoWay}" Width="140" />                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, Mode=TwoWay}" Width="120" />                    <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod, Mode=TwoWay}" Width="*" />                    <DataGridTextColumn Header="Status" Binding="{Binding PaymentStatus, Mode=TwoWay}" Width="*" />                </DataGrid.Columns>            </DataGrid>        </Border>        <Border Grid.Row="2" Background="White" Padding="0,8,0,0" Margin="0,0,0,8">            <Grid ColumnDefinitions="*, Auto">                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding PaymentCancelChangesCommand}" Classes="danger">Cancel Changes</Button>                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding PaymentSaveChangesCommand}" Classes="primary">Save Changes</Button>                </StackPanel>            </Grid>        </Border>    </Grid></UserControl>