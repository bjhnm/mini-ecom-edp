<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             x:Class="mvvm_edp.Views.OrderItemTab"             x:DataType="vm:OrderItemTabViewModel">    <Design.DataContext>        <vm:OrderItemTabViewModel/>    </Design.DataContext>    <Grid Margin="12,0,12,0">        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />        </Grid.RowDefinitions>        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">                    <TextBlock Text="Order Items" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center" />                    <Border Classes="badge" VerticalAlignment="Center">                        <TextBlock Text="{Binding FilteredItems.Count}" Classes="badge" />                    </Border>                </StackPanel>                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                         PlaceholderText="Search by customer, product, order ID..." Classes="search"                         HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24,0,0,0" />            </Grid>        </Border>        <Border Grid.Row="1" Classes="card" Padding="0" Margin="0,0,0,8">            <DataGrid ItemsSource="{Binding FilteredItems}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"                      GridLinesVisibility="Horizontal" BorderThickness="0" AutoGenerateColumns="False" RowHeight="44" CanUserResizeColumns="True">                <DataGrid.Columns>                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" IsReadOnly="True" Width="100" />                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" IsReadOnly="True" Width="*" />                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" IsReadOnly="True" Width="*" />                    <DataGridTextColumn Header="Price" Binding="{Binding ProductPrice}" IsReadOnly="True" Width="100" />                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" IsReadOnly="True" Width="80" />                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" IsReadOnly="True" Width="100" />                </DataGrid.Columns>            </DataGrid>        </Border>    </Grid></UserControl>