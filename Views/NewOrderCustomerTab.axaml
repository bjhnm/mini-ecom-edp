<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.NewOrderCustomerTab"             x:DataType="vm:NewOrderCustomerTabViewModel">    <Design.DataContext>        <!-- This only sets the DataContext for the previewer in an IDE,        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->        <vm:NewOrderCustomerTabViewModel/>    </Design.DataContext>    <Grid>        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />            <RowDefinition Height="Auto" />            <RowDefinition Height="Auto" />        </Grid.RowDefinitions>        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0, 4, 0, 8">            <TextBox Grid.Column="0" PlaceholderText="Search..." HorizontalAlignment="Stretch" VerticalAlignment="Center" Classes="search"></TextBox>            <Button Grid.Column="1" Margin="8, 0, 0, 0" HorizontalAlignment="Center" VerticalAlignment="Stretch" Classes="secondary">Search</Button>        </Grid>        <DataGrid SelectionMode="Extended" ItemsSource="{Binding CustomerList}" SelectedItem="{Binding DataContext.Selected, RelativeSource={RelativeSource AncestorType=UserControl}}" VerticalAlignment="Stretch" GridLinesVisibility="All" Grid.Row="1" AutoGenerateColumns="False" CanUserResizeColumns="True">            <DataGrid.Columns>                <DataGridTextColumn Header="Customer ID" IsReadOnly="True" Binding="{Binding CustomerId}" />                <DataGridTextColumn Header="First Name" Binding="{Binding FirstName, Mode=TwoWay}" />                <DataGridTextColumn Header="Last Name" Binding="{Binding LastName, Mode=TwoWay}" />                <DataGridTextColumn Header="Phone" Binding="{Binding Phone, Mode=TwoWay}" />                <DataGridTextColumn Header="Address" Binding="{Binding Address, Mode=TwoWay}" />            </DataGrid.Columns>        </DataGrid>        <Grid RowDefinitions="Auto, Auto" Grid.Row="2">            <Label Grid.Row="0" HorizontalAlignment="Center" FontWeight="Bold" FontSize="15" Margin="0,5,0,0">Selected Customer</Label>            <Border Grid.Row="1" Margin="0, 8, 0, 8" BorderBrush="#E8E8E8"                    BorderThickness="1"                    Padding="10"                    CornerRadius="8">                <StackPanel >                    <Grid ColumnDefinitions="*, *, *">                        <Grid Grid.Column="0" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">Customer ID: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Selected.CustomerId}"/>                        </Grid>                        <Grid Grid.Column="1" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">First Name: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Selected.FirstName}"/>                        </Grid>                        <Grid Grid.Column="2" ColumnDefinitions="Auto, *">                            <Label Grid.Column="0" VerticalAlignment="Center">Last Name: </Label>                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Selected.LastName}"/>                        </Grid>                    </Grid>                    <Grid ColumnDefinitions="Auto, *">                        <Label Grid.Column="0" VerticalAlignment="Center">Phone: </Label>                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Selected.Phone}"/>                    </Grid>                    <Grid ColumnDefinitions="Auto, *">                        <Label Grid.Column="0" VerticalAlignment="Center">Address: </Label>                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Selected.Address}"/>                    </Grid>                </StackPanel>            </Border>        </Grid>        <Grid ColumnDefinitions="Auto * Auto" Grid.Row="3">            <StackPanel Grid.Column="0" Orientation="Horizontal">                <Button Margin="0, 8, 8, 0" Click="OpenDialogButton_Click"                        Classes="secondary">Create New Customer</Button>            </StackPanel>            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">                <Button Margin="0, 8, 0, 0" Click="CancelDialogButton_Click"                        Classes="secondary">Cancel</Button>                <Button Margin="0, 8, 0, 0"                        Command="{Binding DataContext.NextCommand,                          RelativeSource={RelativeSource AncestorType=UserControl}}"                        Classes="primary">Next</Button>            </StackPanel>        </Grid>    </Grid></UserControl>