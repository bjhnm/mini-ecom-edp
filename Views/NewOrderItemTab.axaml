<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.NewOrderItemTab"             x:DataType="vm:NewOrderItemTabViewModel">    <Design.DataContext>        <!-- This only sets the DataContext for the previewer in an IDE,        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->        <vm:NewOrderItemTabViewModel/>    </Design.DataContext>    <!--    <Window.Styles>    <Style Selector="DataValidationErrors">    <Setter Property="BorderBrush" Value="Red"/>    <Setter Property="BorderThickness" Value="2"/>    </Style>    </Window.Styles>    -->    <Grid RowDefinitions="Auto, *, Auto, *, Auto, Auto" Margin="0">        <Grid Grid.Row="0">            <Label Margin="0, 10, 0, 10" HorizontalAlignment="Center" FontWeight="Bold" FontSize="15">Select Items</Label>        </Grid>        <DataGrid Grid.Row="1" ItemsSource="{Binding ProductList}" VerticalAlignment="Stretch" GridLinesVisibility="All" AutoGenerateColumns="False" CanUserResizeColumns="True">            <DataGrid.Columns>                <DataGridTextColumn Header="ID" IsReadOnly="True" Binding="{Binding ProductId}" Width="50" />                <DataGridTextColumn Header="Name" IsReadOnly="True"  Binding="{Binding Name, Mode=TwoWay}" Width="*" />                <DataGridTextColumn Header="Description" IsReadOnly="True"  Binding="{Binding Description, Mode=TwoWay}" Width="*" />                <DataGridTextColumn Header="Price" IsReadOnly="True"  Binding="{Binding Price, Mode=TwoWay}" Width="80" />                <DataGridTemplateColumn Header="" Width="120">                    <DataGridTemplateColumn.CellTemplate>                        <DataTemplate>                            <Button Content="Add"                                    Classes="primary" Padding="12,4" HorizontalContentAlignment="Center"                                    HorizontalAlignment="Center" VerticalAlignment="Center"                                    Command="{Binding DataContext.ProductToItemCommand,                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"                                    CommandParameter="{Binding}" />                        </DataTemplate>                    </DataGridTemplateColumn.CellTemplate>                </DataGridTemplateColumn>            </DataGrid.Columns>        </DataGrid>        <Grid Grid.Row="2">            <Label Margin="0, 10, 0, 10" HorizontalAlignment="Center" FontWeight="Bold" FontSize="15">Cart</Label>        </Grid>        <DataGrid Grid.Row="3" ItemsSource="{Binding ItemList}" VerticalAlignment="Stretch" GridLinesVisibility="All" AutoGenerateColumns="False" CanUserResizeColumns="True">            <DataGrid.Columns>                <DataGridTextColumn Header="ID" IsReadOnly="True" Binding="{Binding Item.ProductId}" Width="50" />                <DataGridTextColumn Header="Name" IsReadOnly="True"  Binding="{Binding Product.Name, Mode=TwoWay}" Width="*" />                <DataGridTextColumn Header="Description" IsReadOnly="True"  Binding="{Binding Product.Description, Mode=TwoWay}" Width="*" />                <DataGridTextColumn Header="Price" IsReadOnly="True"  Binding="{Binding Product.Price, Mode=TwoWay}" Width="80" />                <DataGridTextColumn Header="Qty"  Binding="{Binding Item.Quantity, Mode=TwoWay}" Width="60" />                <DataGridTemplateColumn Header="" Width="130">                    <DataGridTemplateColumn.CellTemplate>                        <DataTemplate>                            <Button Content="Remove"                                    Classes="danger" Padding="12,4" HorizontalContentAlignment="Center"                                    VerticalAlignment="Center"                                    Command="{Binding DataContext.ItemToProductCommand,                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"                                    CommandParameter="{Binding}" />                        </DataTemplate>                    </DataGridTemplateColumn.CellTemplate>                </DataGridTemplateColumn>            </DataGrid.Columns>        </DataGrid>        <Border Grid.Row="4" Margin="0, 8, 0, 8" BorderBrush="#E8E8E8"                BorderThickness="1"                Padding="10"                CornerRadius="8">            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">                <Label VerticalAlignment="Center" FontSize="20">Total:</Label><TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Black" Text="{Binding Total, StringFormat='{}{0:C}'}"></TextBlock>            </StackPanel>        </Border>        <Grid Grid.Row="5" ColumnDefinitions="*, Auto, Auto">            <Button Grid.Column="1" Margin="0, 0, 8, 0"                    Command="{Binding PreviousTabCommandFromParent}"                    Classes="secondary">Previous</Button>            <Button Grid.Column="2"                    Command="{Binding NextTabCommandFromParent}"                    Classes="primary">Next</Button>        </Grid>    </Grid></UserControl>