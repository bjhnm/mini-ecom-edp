<Window xmlns="https://github.com/avaloniaui"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        xmlns:vm="using:mvvm_edp.ViewModels"        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="565"        Width="400" Height="565"        WindowStartupLocation="CenterScreen"        CanResize="False" CanMaximize="False"        x:Class="mvvm_edp.Views.DatabaseLoginDialog"        x:DataType="vm:DatabaseLoginViewModel"        Icon="/Assets/app.ico"        Title="Database Login">    <Grid RowDefinitions="Auto, *, Auto, Auto" Margin="28">        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,20">            <TextBlock Text="Connect to Database" FontSize="20" FontWeight="Bold"                       Foreground="#1A1A2E" HorizontalAlignment="Center" />            <TextBlock Text="Enter your MySQL database credentials"                       FontSize="13" Foreground="#888"                       HorizontalAlignment="Center" />        </StackPanel>        <ScrollViewer Grid.Row="1">            <StackPanel Spacing="16">                <StackPanel Spacing="4">                    <TextBlock Text="Server" FontSize="13" FontWeight="SemiBold" Foreground="#555" />                    <TextBox Text="{Binding Server}" PlaceholderText="e.g. localhost" />                </StackPanel>                <StackPanel Spacing="4">                    <TextBlock Text="Port" FontSize="13" FontWeight="SemiBold" Foreground="#555" />                    <TextBox Text="{Binding Port}" PlaceholderText="e.g. 3306" />                </StackPanel>                <StackPanel Spacing="4">                    <TextBlock Text="Database" FontSize="13" FontWeight="SemiBold" Foreground="#555" />                    <TextBox Text="{Binding Database}" PlaceholderText="e.g. mini_ecom" />                </StackPanel>                <StackPanel Spacing="4">                    <TextBlock Text="User" FontSize="13" FontWeight="SemiBold" Foreground="#555" />                    <TextBox Text="{Binding User}" PlaceholderText="e.g. root" />                </StackPanel>                <StackPanel Spacing="4">                    <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" Foreground="#555" />                    <TextBox Text="{Binding Password}" PlaceholderText="Password"                             PasswordChar="*" />                </StackPanel>            </StackPanel>        </ScrollViewer>        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"                   Foreground="#d32f2f" FontSize="13" TextWrapping="Wrap"                   Margin="0,12,0,0" />        <StackPanel  Grid.Row="3" Spacing="10" Margin="0,0,0,0">            <Button HorizontalContentAlignment="Center" Command="{Binding ConnectCommand}"                    Classes="primary" HorizontalAlignment="Stretch"                    IsEnabled="{Binding CanConnect}">Connect</Button>            <Button HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" Command="{Binding CancelCommand}"                    Classes="secondary"                    Cursor="Hand">Cancel</Button>        </StackPanel>    </Grid></Window>