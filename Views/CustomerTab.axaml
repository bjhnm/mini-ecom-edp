<UserControl xmlns="https://github.com/avaloniaui"             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="using:mvvm_edp.ViewModels"             xmlns:models="using:mvvm_edp.Models"             x:Class="mvvm_edp.Views.CustomerTab"             x:DataType="vm:CustomerTabViewModel">    <Design.DataContext>        <vm:CustomerTabViewModel/>    </Design.DataContext>    <Grid Margin="12,0,12,0">        <Grid.RowDefinitions>            <RowDefinition Height="Auto" />            <RowDefinition Height="*" />            <RowDefinition Height="Auto" />        </Grid.RowDefinitions>        <Border Grid.Row="0" Background="White" Padding="0,4,0,12">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">                    <TextBlock Text="Customers" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center" />                    <Border Classes="badge" VerticalAlignment="Center">                        <TextBlock Text="{Binding FilteredItems.Count}" Classes="badge" />                    </Border>                </StackPanel>                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                         PlaceholderText="Search customers..." Classes="search"                         HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24,0,0,0" />            </Grid>        </Border>        <Border Grid.Row="1" Classes="card" Padding="0" Margin="0,0,0,8">            <DataGrid ItemsSource="{Binding FilteredItems}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"                      GridLinesVisibility="Horizontal" BorderThickness="0" AutoGenerateColumns="False" RowHeight="44" CanUserResizeColumns="True">                <DataGrid.Columns>                    <DataGridTextColumn Header="Customer ID" IsReadOnly="True" Binding="{Binding CustomerId}" Width="100" />                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName, Mode=TwoWay}" Width="*" />                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName, Mode=TwoWay}" Width="*" />                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone, Mode=TwoWay}" Width="140" />                    <DataGridTextColumn Header="Address" Binding="{Binding Address, Mode=TwoWay}" Width="2*" />                    <DataGridTemplateColumn Header="Delete" Width="80">                        <DataGridTemplateColumn.CellTemplate>                            <DataTemplate DataType="models:Customer">                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>                            </DataTemplate>                        </DataGridTemplateColumn.CellTemplate>                    </DataGridTemplateColumn>                </DataGrid.Columns>            </DataGrid>        </Border>        <Border Grid.Row="2" Background="White" Padding="0,8,0,0" Margin="0,0,0,8">            <Grid ColumnDefinitions="Auto, *, Auto">                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">                    <Button Command="{Binding CreateNewCustomerCommand}" Classes="primary">                        <StackPanel Orientation="Horizontal" Spacing="6">                            <TextBlock VerticalAlignment="Center" Text="+" FontSize="16" FontWeight="Bold" />                            <TextBlock VerticalAlignment="Center" Text="New Customer" />                        </StackPanel>                    </Button>                </StackPanel>                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding CustomerCancelChangesCommand}" Classes="danger">Cancel Changes</Button>                    <Button IsEnabled="{Binding IsChanged}" Command="{Binding CustomerSaveChangesCommand}" Classes="primary">Save Changes</Button>                </StackPanel>            </Grid>        </Border>    </Grid></UserControl>